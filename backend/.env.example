NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/footstream
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=8h
COOKIE_NAME=footstream_token
COOKIE_MAX_AGE_MS=28800000
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=50
PUBLIC_READ_RATE_LIMIT_MAX=2500
CHAT_RATE_LIMIT_MAX=8
SEARCH_RATE_LIMIT_MAX=600
UPLOAD_RATE_LIMIT_MAX=300
JOIN_REQUEST_RATE_LIMIT_MAX=15
MUTATION_RATE_LIMIT_MAX=1500
CHAT_BLOCKED_WORDS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=footstream/matches
SUPER_ADMIN_NAME=FootStream Administrator
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-password
